write_caddy_route() {
  install -d /etc/caddy/conf.d
  cat > "$CADDY_ROUTE" <<EOF
# Generated by \`hostek setup\`. Routes the service API to the hostek Go daemon.
# Imported by holistic's Caddyfile. Caddy matches this more-specific path
# (/api/services/hostek/*) before the generic /api/* handler regardless of import
# order, so it wins.
handle /api/services/hostek/* {
	reverse_proxy 127.0.0.1:$HOSTEK_PORT
}
EOF
}

# ── secret access ───────────────────────────────────────────────────────────────
grant_secret_access() {
  if [ ! -f "$HOLISTIC_SECRET_FILE" ]; then
    warn "$HOLISTIC_SECRET_FILE not found — install the holistic dashboard first"
    return 0
  fi
  getent group "$HOLISTIC_GROUP" >/dev/null \
    || die "group '$HOLISTIC_GROUP' missing — install the dashboard first" 5
  usermod -aG "$HOLISTIC_GROUP" "$HOSTEK_USER"   # must succeed or the daemon can't read the secret
  chgrp "$HOLISTIC_GROUP" "$HOLISTIC_SECRET_FILE"
  chmod 0640 "$HOLISTIC_SECRET_FILE"             # scoped to the holistic + hostek service accounts
}

# ── commands ──────────────────────────────────────────────────────────────────────
cmd_setup() {
  needs_root
  local holistic; holistic="$(detect_holistic_repo)" \
    || die "holistic repo not found — set HOLISTIC_REPO=/path/to/holistic" 5
  log "using holistic repo: $holistic"

  log "system user + directories..."
  getent group "$HOSTEK_USER" >/dev/null || groupadd --system "$HOSTEK_USER"
  getent passwd "$HOSTEK_USER" >/dev/null \
    || useradd --system --gid "$HOSTEK_USER" --shell /usr/sbin/nologin --home-dir /var/lib/hostek "$HOSTEK_USER"
  install -d -o "$HOSTEK_USER" -g "$HOSTEK_USER" -m 0755 "$HOSTEK_APP" "$HOSTEK_APP/bin" /etc/hostek /var/lib/hostek

  build_daemon

  log "installing privileged wrappers + sudoers..."
  write_power_wrapper
  write_tmux_wrapper
  write_hwinfo_wrapper
  write_netmon_wrapper
  write_powermon_wrapper
  write_diskctl_wrapper
  write_sudoers
  assert_safe_perms "$WRAPPER" "$TMUX_WRAPPER" "$HWINFO_WRAPPER" "$NETMON_WRAPPER" "$POWERMON_WRAPPER" "$DISKCTL_WRAPPER" "$SUDOERS"

  ensure_optional_tools

  log "granting read on the shared JWT secret..."
  grant_secret_access

  log "configuring systemd..."
  write_unit
  systemctl daemon-reload
  systemctl enable hostek >/dev/null 2>&1 || true

  log "adding Caddy route..."
  write_caddy_route

  log "declaring rights (permissions.d) + backing groups..."
  write_permissions

  log "linking UI plugin into holistic + rebuilding dashboard SPA..."
  install -d "$holistic/frontend/external"
  ln -sfn "$REPO_ROOT/ui" "$holistic/frontend/external/hostek"
  # Rebuilds the SPA (now bundling hostek's plugin), recopies www, reinstalls the
  # import-enabled Caddyfile, and reloads Caddy — picking up conf.d/hostek.caddy.
  "$holistic/holistic" setup dashboard

  systemctl restart hostek
  if ! systemctl is-active --quiet hostek; then
    journalctl -u hostek -n 20 --no-pager >&2 || true
    die "hostek failed to start" 4
  fi
  log "installed and started — \"System\" is live in the holistic sidebar"
}

cmd_build() {
  needs_root
  build_daemon
  if systemctl is-active --quiet hostek; then
    systemctl restart hostek
    log "rebuilt and restarted hostekd"
  else
    log "rebuilt hostekd (service not running)"
  fi
}

cmd_lifecycle() {
  needs_root
  local action="$1"
  systemctl "$action" hostek && log "$action: hostek" \
    || die "'$action hostek' failed — installed? run 'sudo $0 setup'"
}

cmd_power() {
  needs_root
  case "${1:-}" in
    on|off) "$WRAPPER" "$1" ;;
    *) die "usage: hostek power on|off" 2 ;;
  esac
}

cmd_tmux() {
  needs_root
  case "${1:-}" in
    on|off|resume-on|resume-off) "$TMUX_WRAPPER" "$1" ;;
    *) die "usage: hostek tmux on|off|resume-on|resume-off" 2 ;;
  esac
}

cmd_update() {
  log "pulling latest..."
  git -C "$REPO_ROOT" pull --ff-only
  cmd_setup
}

cmd_status() {
  local holistic plugin state
  state="$(systemctl is-active hostek 2>/dev/null || true)"
  echo "── hostek $HOSTEK_VERSION ──"
  printf '  %-16s %s\n' "daemon:"  "${state:-unknown}"
  printf '  %-16s %s\n' "listen:"  "127.0.0.1:$HOSTEK_PORT"
  printf '  %-16s %s\n' "binary:"  "$([ -x "$HOSTEK_APP/bin/hostekd" ] && echo "$HOSTEK_APP/bin/hostekd" || echo '(not built)')"
  # Wrappers are root-only 0750, so test existence (-e), not executability by this user.
  printf '  %-16s %s\n' "wrapper:" "$([ -e "$WRAPPER" ] && echo present || echo missing)"
  printf '  %-16s %s\n' "tmux:"    "$([ -e "$TMUX_WRAPPER" ] && echo present || echo missing)"
  printf '  %-16s %s\n' "hwinfo:"  "$([ -e "$HWINFO_WRAPPER" ] && echo present || echo missing)"
  printf '  %-16s %s\n' "netmon:"  "$([ -e "$NETMON_WRAPPER" ] && echo present || echo missing)"
  printf '  %-16s %s\n' "powermon:" "$([ -e "$POWERMON_WRAPPER" ] && echo present || echo missing)"
  printf '  %-16s %s\n' "diskctl:" "$([ -e "$DISKCTL_WRAPPER" ] && echo present || echo missing)"
  printf '  %-16s %s\n' "route:"   "$([ -f "$CADDY_ROUTE" ] && echo "$CADDY_ROUTE" || echo missing)"
  if holistic="$(detect_holistic_repo 2>/dev/null)"; then
    plugin="$holistic/frontend/external/hostek"
    printf '  %-16s %s\n' "plugin:" "$([ -L "$plugin" ] && echo "linked ($holistic)" || echo "missing ($holistic)")"
  else
    printf '  %-16s %s\n' "plugin:" "(holistic repo not found)"
  fi
  if command -v systemctl >/dev/null; then
    echo
    echo "── systemctl status hostek ──"
    systemctl --no-pager --lines=3 status hostek 2>&1 || true
  fi
}

cmd_uninstall() {
  needs_root
  local purge=0
  [ "${1:-}" = "--purge" ] && purge=1
  confirm "remove hostek from this server${purge:+ (and purge user + $HOSTEK_APP)}?" || die "aborted" 10

  systemctl disable --now hostek >/dev/null 2>&1 || true
  rm -f "$UNIT"; systemctl daemon-reload
  rm -f "$CADDY_ROUTE" "$SUDOERS" "$WRAPPER" "$TMUX_WRAPPER" "$HWINFO_WRAPPER" "$NETMON_WRAPPER" "$POWERMON_WRAPPER" "$DISKCTL_WRAPPER" "$PERMS_FILE"
  rm -f /etc/profile.d/hostek-tmux.sh   # drop the SSH→tmux routing snippet too

  local holistic
  if holistic="$(detect_holistic_repo 2>/dev/null)"; then
    rm -f "$holistic/frontend/external/hostek"
    log "rebuilding dashboard SPA without hostek..."
    "$holistic/holistic" setup dashboard || warn "dashboard rebuild failed — run it manually to drop the System tab"
  else
    warn "holistic repo not found — remove frontend/external/hostek + rebuild the SPA manually"
  fi

  if [ "$purge" = "1" ]; then
    userdel "$HOSTEK_USER" >/dev/null 2>&1 || true
    groupdel "$HOSTEK_USER" >/dev/null 2>&1 || true
    local g
    for g in hp_hostek_power hp_hostek_proc hp_hostek_hwdetail hp_hostek_techinfo hp_hostek_thermal hp_hostek_powerinfo hp_hostek_disks hp_hostek_mount hp_hostek_eject; do
      groupdel "$g" >/dev/null 2>&1 || true
    done
    rm -rf "$HOSTEK_APP" /etc/hostek /var/lib/hostek
    log "purged user, rights groups, $HOSTEK_APP, /etc/hostek, /var/lib/hostek"
  fi
  log "uninstalled"
}

cmd_help() {
  cat <<EOF
hostek $HOSTEK_VERSION — live server metrics & configuration, as a holistic service.

Usage:
  hostek setup                  Install/repair hostek as a holistic service (builds the
                                daemon, wires systemd + sudo + Caddy, links the UI plugin
                                and rebuilds the dashboard SPA). Self-elevates via sudo.
  hostek build                  Rebuild the Go daemon only, then restart if running
  hostek start|stop|restart     Control the hostek daemon
  hostek status                 Show daemon, route, and plugin-link health
  hostek power on|off           Toggle OS headless / always-on power settings
  hostek tmux on|off            Toggle routing interactive SSH logins through tmux
  hostek update                 git pull --ff-only + re-run setup
  hostek uninstall [--purge]    Remove hostek (--purge also drops the user + $HOSTEK_APP)
  hostek help | version

Quickstart:
  sudo ./hostek setup           # HOLISTIC_REPO is autodetected (sibling ../holistic, /code/holistic, …)

Env (override defaults):
  HOLISTIC_REPO   path to the holistic repo (autodetected if unset)
  HOSTEK_PORT     loopback port for hostekd (default $HOSTEK_PORT)
  HOSTEK_YES=1    skip confirmation prompts   ·   HOSTEK_QUIET=1  only warnings/errors

Generated artifacts (this script is their source of truth):
  $UNIT
  $CADDY_ROUTE
  $SUDOERS
  $PERMS_FILE
  $WRAPPER
  $TMUX_WRAPPER
  $HWINFO_WRAPPER
  $DISKCTL_WRAPPER
  $NETMON_WRAPPER
  $POWERMON_WRAPPER

Exit codes: 0 ok · 1 generic · 2 usage · 4 external · 5 config-state · 10 declined
EOF
}

# ── dispatch ──────────────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    setup)                cmd_setup "$@" ;;
    build)                cmd_build "$@" ;;
    start|stop|restart)   cmd_lifecycle "$cmd" ;;
    status)               cmd_status "$@" ;;
    power)                cmd_power "$@" ;;
    tmux)                 cmd_tmux "$@" ;;
    update)               cmd_update "$@" ;;
    uninstall)            cmd_uninstall "$@" ;;
    version|-v|--version) echo "hostek $HOSTEK_VERSION" ;;
    help|-h|--help)       cmd_help ;;
    *) die "unknown command: $cmd (run 'hostek help')" 2 ;;
  esac
}

main "$@"
