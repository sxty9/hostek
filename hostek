#!/usr/bin/env bash
# hostek — live server metrics & configuration, as a holistic service.
# Single-file bash CLI (sxgate-style): owns install, lifecycle, and the OS config surface.
# Runs on stock Ubuntu; the systemd unit, Caddy route, sudoers drop-in and the privileged
# power/tmux wrappers are all generated inline by `hostek setup` — this script is their
# source of truth (no separate install script, no deploy/ tree).

set -euo pipefail

HOSTEK_VERSION="0.1.0"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ORIG_ARGS=("$@")

# ── config (override via env) ───────────────────────────────────────────────────
: "${HOLISTIC_REPO:=}"                                  # holistic repo; autodetected if empty
: "${HOSTEK_APP:=/opt/hostek}"                          # install prefix (binary lives here)
: "${HOSTEK_USER:=hostek}"                              # unprivileged system user
: "${HOSTEK_PORT:=8771}"                                # loopback port for hostekd
: "${HOSTEK_ADMIN_GROUP:=sudo}"                         # Linux group that is "admin"
: "${HOLISTIC_SECRET_FILE:=/etc/holistic/jwt-secret}"   # shared session-signing secret
: "${HOLISTIC_GROUP:=holistic}"                         # group that owns the shared secret

WRAPPER=/usr/local/sbin/hostek-power-set
TMUX_WRAPPER=/usr/local/sbin/hostek-tmux-set
HWINFO_WRAPPER=/usr/local/sbin/hostek-hwinfo
NETMON_WRAPPER=/usr/local/sbin/hostek-netmon
POWERMON_WRAPPER=/usr/local/sbin/hostek-powermon
DISKCTL_WRAPPER=/usr/local/sbin/hostek-diskctl
SUDOERS=/etc/sudoers.d/hostek
UNIT=/etc/systemd/system/hostek.service
CADDY_ROUTE=/etc/caddy/conf.d/hostek.caddy
PERMS_FILE=/etc/holistic/permissions.d/hostek.json

# ── output ──────────────────────────────────────────────────────────────────────
log()  { [ "${HOSTEK_QUIET:-0}" = "1" ] || printf '[hostek] %s\n' "$*"; }
warn() { printf '[hostek] warning: %s\n' "$*" >&2; }
die()  { printf '[hostek] error: %s\n' "$*" >&2; exit "${2:-1}"; }

confirm() {
  [ "${HOSTEK_YES:-0}" = "1" ] && return 0
  local reply
  printf '[hostek] %s [y/N] ' "$1" >&2
  read -r reply || return 1
  [[ "$reply" =~ ^[yY]$ ]]
}

# Re-exec under sudo, preserving env + the original argv, so users never have to type it.
needs_root() {
  [ "$(id -u)" -eq 0 ] && return 0
  command -v sudo >/dev/null || die "must run as root (sudo not found)"
  exec sudo -E "$0" "${ORIG_ARGS[@]}"
}

# A NOPASSWD-to-root wrapper that is not root-owned or is group/other-writable is an
# escalation. Refuse to keep it installed. (holistic's assert_safe_perms, normalized.)
assert_safe_perms() {
  local f owner mode
  for f in "$@"; do
    [ -e "$f" ] || continue
    owner="$(stat -c '%U' "$f")"
    mode="$(stat -c '%a' "$f")"
    [ "$owner" = "root" ] || die "$f not owned by root (owner=$owner)"
    if [[ "${mode: -1}" =~ [2367] || "${mode: -2:1}" =~ [2367] ]]; then
      die "$f is group/other-writable (mode=$mode)"
    fi
  done
}

# ── holistic repo discovery ──────────────────────────────────────────────────────
is_holistic_repo() { [ -x "$1/holistic" ] && [ -f "$1/frontend/app/src/registry.ts" ]; }

detect_holistic_repo() {
  if [ -n "$HOLISTIC_REPO" ]; then
    is_holistic_repo "$HOLISTIC_REPO" \
      || die "HOLISTIC_REPO=$HOLISTIC_REPO is not a holistic repo (missing ./holistic or frontend)"
    ( cd "$HOLISTIC_REPO" && pwd ); return 0
  fi
  local c
  for c in "$REPO_ROOT/../holistic" /code/holistic "$HOME/holistic" /home/*/holistic; do
    [ -e "$c" ] && is_holistic_repo "$c" && { ( cd "$c" && pwd ); return 0; }
  done
  return 1
}

# ── build ─────────────────────────────────────────────────────────────────────────
ensure_go() {
  command -v go >/dev/null && return 0
  log "installing Go toolchain..."
  apt-get update -qq
  apt-get install -y -qq golang-go >/dev/null
  command -v go >/dev/null || die "Go install failed" 4
}

build_daemon() {
  ensure_go
  log "building hostekd..."
  install -d -o "$HOSTEK_USER" -g "$HOSTEK_USER" -m 0755 "$HOSTEK_APP" "$HOSTEK_APP/bin"
  ( cd "$REPO_ROOT/backend" && GOCACHE=/tmp/hostek-gocache go build -o "$HOSTEK_APP/bin/hostekd" ./cmd/hostekd )
  chown -R "$HOSTEK_USER:$HOSTEK_USER" "$HOSTEK_APP"
}

# ── inline artifact generators ─────────────────────────────────────────────────────
write_power_wrapper() {
  # Privileged on|off toggle for OS-level headless/always-on power settings. Outer
  # delimiter is quoted, so the inner heredoc + $vars are written verbatim into the file.
  cat > "$WRAPPER" <<'POWERSCRIPT'
#!/usr/bin/env bash
# hostek-power-set on|off — toggle OS-level "headless / always-on" power settings.
# Generated by `hostek setup`; root-owned 0750, invoked by hostekd via `sudo -n`.
# Idempotent. The BIOS "Restore AC Power Loss" setting is firmware-level (UEFI), not here.
set -euo pipefail

DROPIN=/etc/systemd/logind.conf.d/10-hostek-headless.conf
SLEEP_TARGETS=(sleep.target suspend.target hibernate.target hybrid-sleep.target)

case "${1:-}" in
  on)
    install -d -m 0755 /etc/systemd/logind.conf.d
    cat > "$DROPIN" <<'EOF'
# Managed by hostek — keep a headless server running without a monitor.
[Login]
HandleLidSwitch=ignore
HandleLidSwitchExternalPower=ignore
HandleLidSwitchDocked=ignore
EOF
    systemctl mask "${SLEEP_TARGETS[@]}" >/dev/null 2>&1 || true
    systemctl restart systemd-logind >/dev/null 2>&1 || true
    echo "[hostek] headless mode enabled"
    ;;
  off)
    rm -f "$DROPIN"
    systemctl unmask "${SLEEP_TARGETS[@]}" >/dev/null 2>&1 || true
    systemctl restart systemd-logind >/dev/null 2>&1 || true
    echo "[hostek] headless mode disabled"
    ;;
  *)
    echo "usage: hostek-power-set on|off" >&2
    exit 2
    ;;
esac
POWERSCRIPT
  chown root:root "$WRAPPER"
  chmod 0750 "$WRAPPER"
}

write_tmux_wrapper() {
  # Privileged toggle for tmux-backed SSH session persistence. "on" installs a /etc/profile.d
  # snippet that re-exec's each interactive SSH login into its OWN persistent tmux session, so
  # remote work (e.g. the Claude CLI) survives disconnects — laptop sleep, network drop, idle
  # timeout — while concurrent logins stay independent (the non-tmux luxury). The "resume-on"
  # sub-toggle drops a marker (/etc/hostek/tmux-resume) so a login instead reattaches to an
  # orphaned (detached) session left by a dropped connection. Outer delimiter is quoted, so the
  # inner heredoc + $vars are written verbatim into the file.
  cat > "$TMUX_WRAPPER" <<'TMUXSCRIPT'
#!/usr/bin/env bash
# hostek-tmux-set on|off|resume-on|resume-off — route interactive SSH logins through per-login
# tmux sessions, optionally resuming orphaned ones. Generated by `hostek setup`; root-owned
# 0750, invoked by hostekd via `sudo -n`. Idempotent.
set -euo pipefail

PROFILE=/etc/profile.d/hostek-tmux.sh
RESUME=/etc/hostek/tmux-resume

case "${1:-}" in
  on)
    # Best-effort: pull tmux in if missing. Without it the snippet is a harmless no-op.
    command -v tmux >/dev/null 2>&1 \
      || { command -v apt-get >/dev/null 2>&1 && apt-get install -y -qq tmux >/dev/null 2>&1; } \
      || true
    cat > "$PROFILE" <<'EOF'
# Managed by hostek — keep remote work alive across SSH disconnects. Each interactive SSH login
# gets its OWN persistent tmux session, so concurrent logins stay independent (the non-tmux
# luxury). If /etc/hostek/tmux-resume exists, a login instead reattaches to the most-recently-
# active DETACHED session when one is free — resuming work left by a dropped connection — and
# only starts fresh when none is orphaned. Fires only for interactive SSH login shells on a tty,
# with tmux present and not already inside tmux, so scp/sftp/rsync and `ssh host <cmd>` are
# untouched. Sourced into the login shell, so no `set -e` reliance here.
if [ -n "${SSH_CONNECTION:-}" ] && [ -z "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
  case "$-" in
    *i*)
      if [ -t 0 ]; then
        if [ -f /etc/hostek/tmux-resume ]; then
          __hostek_sid=$(tmux list-sessions -F '#{session_attached} #{session_activity} #{session_id}' 2>/dev/null \
                         | awk '$1==0 {print $2" "$3}' | sort -rn | awk 'NR==1{print $2}')
          [ -n "$__hostek_sid" ] && exec tmux attach-session -t "$__hostek_sid"
        fi
        exec tmux new-session
      fi
      ;;
  esac
fi
EOF
    chmod 0644 "$PROFILE"
    echo "[hostek] tmux SSH session persistence enabled"
    ;;
  off)
    rm -f "$PROFILE" "$RESUME"
    echo "[hostek] tmux SSH session persistence disabled"
    ;;
  resume-on)
    mkdir -p /etc/hostek
    : > "$RESUME"
    echo "[hostek] tmux orphan-session resume enabled"
    ;;
  resume-off)
    rm -f "$RESUME"
    echo "[hostek] tmux orphan-session resume disabled"
    ;;
  *)
    echo "usage: hostek-tmux-set on|off|resume-on|resume-off" >&2
    exit 2
    ;;
esac
TMUXSCRIPT
  chown root:root "$TMUX_WRAPPER"
  chmod 0750 "$TMUX_WRAPPER"
}

write_hwinfo_wrapper() {
  # Read-only hardware probe for the System tab. Each keyword maps to ONE fixed read-only
  # command (no writes, no shell injection: `smart` validates its device argument). Quoted
  # delimiter → the script is written verbatim.
  cat > "$HWINFO_WRAPPER" <<'HWINFO'
#!/usr/bin/env bash
# hostek-hwinfo <keyword> [arg] — privileged read-only hardware probe for hostekd.
# Generated by `hostek setup`; root-owned 0750, invoked via `sudo -n`. Missing tools exit
# nonzero and the daemon treats that as "no data". Nothing here writes to the system.
set -euo pipefail
case "${1:-}" in
  dmidecode-processor) exec dmidecode -t processor ;;
  dmidecode-memory)    exec dmidecode -t memory ;;
  dmidecode-baseboard) exec dmidecode -t baseboard ;;
  dmidecode-bios)      exec dmidecode -t bios ;;
  decode-dimms)        exec decode-dimms ;;
  smart)
    dev="${2:-}"
    [[ "$dev" =~ ^/dev/[a-zA-Z0-9]+$ ]] || { echo "hostek-hwinfo: invalid device" >&2; exit 2; }
    # JSON (-aj) is parsed by hostekd. smartctl's exit code is a bitmask: bits 0-2
    # are usage/open/read errors (propagate → daemon treats as "no data"); bits 3-7
    # are SMART warnings (drive failing/prefail/log errors) where the JSON is still
    # valid and is exactly the health info we want to surface — so keep it, exit 0.
    if out=$(smartctl -aj "$dev"); then rc=0; else rc=$?; fi
    printf '%s\n' "$out"
    if (( rc & 0x07 )); then exit "$rc"; fi
    exit 0
    ;;
  *) echo "usage: hostek-hwinfo {dmidecode-processor|dmidecode-memory|dmidecode-baseboard|dmidecode-bios|decode-dimms|smart <dev>}" >&2; exit 2 ;;
esac
HWINFO
  chown root:root "$HWINFO_WRAPPER"
  chmod 0750 "$HWINFO_WRAPPER"
}

write_diskctl_wrapper() {
  # The only wrapper that *changes* storage state: mount/unmount a partition, or safely
  # remove a whole disk. hostekd validates before calling, but this script is reachable
  # through sudo on its own, so it re-derives every guard from the kernel itself and
  # trusts nothing it is told. Quoted delimiter → written verbatim.
  cat > "$DISKCTL_WRAPPER" <<'DISKCTL'
#!/usr/bin/env bash
# hostek-diskctl {mount|unmount|eject} /dev/X — privileged storage actions for hostekd.
# Generated by `hostek setup`; root-owned 0750, invoked via `sudo -n`.
#
# The safety model, in one place:
#   • The argument must name a block device that exists RIGHT NOW; the kind is read from
#     the kernel (whole disk vs partition), never inferred from the string.
#   • The running system's storage is untouchable: the disk carrying / cannot be ejected,
#     and the mounts the OS lives on (/, /boot, /usr, /var, …) cannot be unmounted.
#   • Mounts of a drive someone just plugged in get nosuid,nodev — an untrusted filesystem
#     must not be able to introduce setuid binaries or device nodes.
# Exit codes: 2 bad request · 3 refused (system storage) · 4 busy/failed · 5 unsupported.
set -euo pipefail

verb="${1:-}"
dev="${2:-}"

# One shape only: /dev/<name>, no slashes, no traversal, no shell metacharacters.
[[ "$dev" =~ ^/dev/[a-zA-Z0-9]+$ ]] || { echo "invalid device" >&2; exit 2; }
[ -b "$dev" ] || { echo "no such block device: $dev" >&2; exit 2; }
name="${dev#/dev/}"

# The mounts the running system is built on. Unmounting any of these breaks the box, so
# they are refused no matter which partition claims them.
protected_mount() {
  case "$1" in
    /|/boot|/boot/*|/usr|/usr/*|/var|/var/*|/etc|/etc/*|/proc|/proc/*|/sys|/sys/*|/run|/run/*|/dev|/dev/*) return 0 ;;
    *) return 1 ;;
  esac
}

# The whole disk that carries "/" — the one disk that must never be detached. Derived from
# the kernel: the root filesystem's source device, walked up to its parent disk (PKNAME is
# empty when root sits directly on the disk, hence the fallback).
root_disk() {
  local src parent
  src="$(findmnt -no SOURCE / 2>/dev/null || true)"
  [ -n "$src" ] || return 0
  parent="$(lsblk -no PKNAME "$src" 2>/dev/null | head -n1 | tr -d ' ' || true)"
  [ -n "$parent" ] || parent="$(lsblk -no NAME -d "$src" 2>/dev/null | head -n1 | tr -d ' ' || true)"
  printf '%s' "$parent"
}

# True if any mountpoint anywhere in this whole disk's holder tree is a system mount. This
# is what makes the eject guard robust to LVM/LUKS/mdraid: when "/" lives on a dm/md device
# stacked on the disk, the disk's own partitions carry no mountpoint, but lsblk still lists
# the stacked node (and its "/" mountpoint) as part of the disk's tree.
disk_holds_system() {
  local mp
  while read -r mp; do
    [ -n "$mp" ] || continue
    protected_mount "$mp" && return 0
  done < <(lsblk -nrpo MOUNTPOINT "$1" 2>/dev/null || true)
  return 1
}

# Every device node in a whole disk's tree — the disk, its partitions, and anything stacked
# on them (LVM/LUKS/md) — deepest first, so a release walk unmounts children before parents.
disk_tree_leaf_first() { lsblk -nrpo NAME "$1" 2>/dev/null | tac; }

# Unmount one device node, plus deactivate it if it is live swap. -A unmounts every
# mountpoint the device is attached to (bind mounts included).
release_device() {
  local d="$1" tgt
  while read -r tgt; do
    [ -n "$tgt" ] || continue
    if protected_mount "$tgt"; then
      echo "refusing to unmount $tgt — the system runs from it" >&2; exit 3
    fi
  done < <(findmnt -nro TARGET -S "$d" 2>/dev/null || true)

  # The tools' own stderr is suppressed throughout: this wrapper's message is the one the
  # user sees (hostekd forwards stderr verbatim), so it must not arrive stacked on top of
  # "umount: /media/hostek/X: target is busy." saying the same thing twice.
  if grep -qs "^$d " /proc/swaps; then
    swapoff "$d" 2>/dev/null || { echo "cannot deactivate swap on $d — it is in use" >&2; exit 4; }
  fi
  if [ -n "$(findmnt -nro TARGET -S "$d" 2>/dev/null)" ]; then
    umount -A "$d" 2>/dev/null || { echo "cannot unmount $d — target is busy" >&2; exit 4; }
  fi
}

case "$verb" in
  mount)
    [ -e "/sys/class/block/$name/partition" ] || { echo "$dev is not a partition" >&2; exit 2; }
    # Already mounted → report where, and succeed. The UI polls; racing it is not an error.
    cur="$(findmnt -nro TARGET -S "$dev" 2>/dev/null | head -n1 || true)"
    if [ -n "$cur" ]; then printf '%s\n' "$cur"; exit 0; fi

    fstype="$(lsblk -nro FSTYPE "$dev" 2>/dev/null | head -n1 || true)"
    [ -n "$fstype" ] || { echo "$dev holds no mountable filesystem" >&2; exit 5; }
    case "$fstype" in
      swap|crypto_LUKS|LVM2_member|linux_raid_member|zfs_member)
        echo "$dev is a $fstype volume, not a plain filesystem" >&2; exit 5 ;;
    esac

    # An fstab entry names where the admin wants this device — honour the TARGET, but NEVER
    # its options. fstab matches by LABEL=/UUID=, and those are read off the drive, so a
    # hostile disk can forge a tag that matches an admin entry; a bare `mount "$dev"` would
    # then apply that entry's options (usually 'defaults' = suid,dev,exec) and let the drive
    # bring a setuid-root binary onto the system. Force nosuid,nodev regardless — the same
    # floor the fallback path uses; a command-line -o overrides the fstab options.
    # `|| true` is load-bearing: with no fstab match `findmnt -s` exits 1, and under
    # `set -euo pipefail` a bare command-substitution assignment would abort the whole
    # wrapper with exit 1 — the no-fstab case is exactly the common one (mounting a plain
    # data partition), so without this the fallback path below is never reached.
    ftgt="$(findmnt -snro TARGET -S "$dev" 2>/dev/null | head -n1 || true)"
    if [ -n "$ftgt" ]; then
      mount -o nosuid,nodev "$dev" "$ftgt" 2>/dev/null || { echo "cannot mount $dev at $ftgt" >&2; exit 4; }
      printf '%s\n' "$ftgt"
      exit 0
    fi

    # Otherwise: /media/hostek/<label|uuid|name>, hardened. nosuid,nodev because the drive
    # is untrusted; the filesystem itself decides whether it can do anything else.
    label="$(lsblk -nro LABEL "$dev" 2>/dev/null | head -n1 || true)"
    uuid="$(lsblk -nro UUID "$dev" 2>/dev/null | head -n1 || true)"
    base="$label"; [ -n "$base" ] || base="$uuid"; [ -n "$base" ] || base="$name"
    base="$(printf '%s' "$base" | tr -c 'A-Za-z0-9._-' '_')"
    # The label comes off the drive itself, i.e. from whoever formatted it — so it is
    # attacker-controlled input. Sanitising the characters is not enough: a drive labelled
    # ".." would still resolve /media/hostek/.. to /media and mount straight over it. Demand
    # a leading alphanumeric, which "." and ".." cannot satisfy, and fall back to the kernel
    # name (always safe) for anything else.
    [[ "$base" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || base="$name"
    target="/media/hostek/$base"
    mkdir -p "$target"
    if ! mount -o nosuid,nodev "$dev" "$target" 2>/dev/null; then
      rmdir "$target" 2>/dev/null || true
      echo "cannot mount $dev ($fstype) — the filesystem was refused by the kernel" >&2; exit 4
    fi
    printf '%s\n' "$target"
    ;;

  unmount)
    [ -e "/sys/class/block/$name/partition" ] || { echo "$dev is not a partition" >&2; exit 2; }
    tgt="$(findmnt -nro TARGET -S "$dev" 2>/dev/null | head -n1 || true)"
    [ -n "$tgt" ] || { echo "$dev is not mounted" >&2; exit 2; }
    release_device "$dev"
    # Clean up an empty directory we created ourselves; never touch anything else.
    case "$tgt" in /media/hostek/*) rmdir "$tgt" 2>/dev/null || true ;; esac
    ;;

  eject)
    [ -d "/sys/block/$name" ] || { echo "$dev is not a whole disk" >&2; exit 2; }
    # Two independent system-disk guards. root_disk() catches the common case (root on a
    # bare partition); disk_holds_system() catches the one it cannot — root (or /boot, /usr,
    # …) on an LVM/LUKS/md device stacked on this disk, where the disk's partitions expose no
    # mountpoint of their own. Either firing refuses the eject.
    rd="$(root_disk)"
    if { [ -n "$rd" ] && [ "$rd" = "$name" ]; } || disk_holds_system "$dev"; then
      echo "refusing to eject $dev — the system runs from it" >&2; exit 3
    fi

    # Release every mounted filesystem / active swap in the disk's tree, deepest node first,
    # so stacked devices (LVM/LUKS on a partition, or a plain partition) come down before the
    # nodes beneath them. release_device still refuses any protected mount as a final backstop.
    while read -r node; do
      [ -n "$node" ] || continue
      release_device "$node"
    done < <(disk_tree_leaf_first "$dev")

    sync
    blockdev --flushbufs "$dev" 2>/dev/null || true

    # Detach. SATA/SAS/USB disks have a SCSI device the kernel can delete; an NVMe namespace
    # hangs off a PCIe controller, so the controller is what gets removed.
    if [ -w "/sys/block/$name/device/delete" ]; then
      echo 1 > "/sys/block/$name/device/delete"
    elif [ -w "/sys/block/$name/device/device/remove" ]; then
      echo 1 > "/sys/block/$name/device/device/remove"
    else
      echo "$dev has no kernel detach path — unmounted, but still attached" >&2; exit 5
    fi
    ;;

  *)
    echo "usage: hostek-diskctl {mount|unmount|eject} /dev/<device>" >&2; exit 2 ;;
esac
DISKCTL
  chown root:root "$DISKCTL_WRAPPER"
  chmod 0750 "$DISKCTL_WRAPPER"
}

write_netmon_wrapper() {
  # Streams per-process network throughput (nethogs trace mode), which Linux does not expose
  # unprivileged. Launched as a long-lived `sudo -n` co-process by hostekd. Optional: without
  # nethogs it exits and the Network column simply shows "—".
  cat > "$NETMON_WRAPPER" <<'NETMON'
#!/usr/bin/env bash
# hostek-netmon — stream per-process network throughput for hostekd (privileged).
# Generated by `hostek setup`; root-owned 0750, launched via `sudo -n`.
set -euo pipefail
command -v nethogs >/dev/null || { echo "hostek-netmon: nethogs not installed" >&2; exit 3; }
exec nethogs -t 2>/dev/null
NETMON
  chown root:root "$NETMON_WRAPPER"
  chmod 0750 "$NETMON_WRAPPER"
}

write_powermon_wrapper() {
  # Streams CPU package power (watts) from RAPL, whose energy counter is root-only
  # (Platypus mitigation). Long-lived `sudo -n` co-process; emits one watts value per
  # interval. Optional: without an Intel/AMD RAPL domain it exits and CPU power reads 0.
  cat > "$POWERMON_WRAPPER" <<'POWERMON'
#!/usr/bin/env bash
# hostek-powermon — stream CPU package power (W) from RAPL for hostekd (privileged).
# Generated by `hostek setup`; root-owned 0750, launched via `sudo -n`.
set -euo pipefail
dom=""
for d in /sys/class/powercap/intel-rapl:0 /sys/class/powercap/intel-rapl/intel-rapl:0; do
  [ -r "$d/energy_uj" ] && { dom="$d"; break; }
done
[ -n "$dom" ] || { echo "hostek-powermon: no readable RAPL domain" >&2; exit 3; }
maxr=$(cat "$dom/max_energy_range_uj" 2>/dev/null || echo 0)
prev=$(cat "$dom/energy_uj")
interval=2
while sleep "$interval"; do
  cur=$(cat "$dom/energy_uj") || break
  d=$((cur - prev)); prev=$cur
  [ "$d" -lt 0 ] && [ "$maxr" -gt 0 ] && d=$((d + maxr))   # counter wrap
  awk -v d="$d" -v t="$interval" 'BEGIN{ printf "%.2f\n", d/t/1000000 }'
done
POWERMON
  chown root:root "$POWERMON_WRAPPER"
  chmod 0750 "$POWERMON_WRAPPER"
}

# Optional probe tooling. Best-effort: the daemon degrades to blank fields without these.
ensure_optional_tools() {
  command -v apt-get >/dev/null || return 0
  log "installing optional hardware/network probe tools (best-effort)..."
  apt-get install -y -qq lshw dmidecode smartmontools nethogs i2c-tools pciutils tmux >/dev/null 2>&1 \
    || warn "some optional probe tools could not be installed — affected metrics will be blank"
}

write_sudoers() {
  # Validate a temp copy before trusting it as a NOPASSWD-to-root grant.
  local tmp; tmp="$(mktemp)"
  cat > "$tmp" <<EOF
# Generated by \`hostek setup\`. hostek's daemon runs unprivileged and escalates ONLY to
# these fixed, read-only/narrow wrappers. Installed root:root 0440 at $SUDOERS (validated by
# visudo). Never touch /etc/sudoers.d/holistic from hostek.
$HOSTEK_USER ALL=(root) NOPASSWD: $WRAPPER, $TMUX_WRAPPER, $HWINFO_WRAPPER, $NETMON_WRAPPER, $POWERMON_WRAPPER, $DISKCTL_WRAPPER
EOF
  if ! visudo -cf "$tmp" >/dev/null; then
    rm -f "$tmp"; die "sudoers validation failed" 4
  fi
  install -m 0440 -o root -g root "$tmp" "$SUDOERS"
  rm -f "$tmp"
}

write_unit() {
  cat > "$UNIT" <<EOF
[Unit]
Description=hostek — live server metrics & configuration (holistic service)
After=network.target holistic-dashboard.service

[Service]
User=$HOSTEK_USER
Group=$HOSTEK_USER
# Validate the same session as the dashboard via the shared JWT secret.
Environment=HOLISTIC_SECRET_FILE=$HOLISTIC_SECRET_FILE
# Admin = single Linux source of truth (the sudo group).
Environment=HOSTEK_ADMIN_GROUP=$HOSTEK_ADMIN_GROUP
ExecStart=$HOSTEK_APP/bin/hostekd --listen 127.0.0.1:$HOSTEK_PORT
Restart=on-failure
RestartSec=2
# Must be false: the daemon escalates via the narrow sudo wrapper allowlist for config writes.
NoNewPrivileges=false
# Conservative hardening. Deliberately OMITTED (they would break the sudo escalation or the
# wrapper's writes under /etc): ProtectSystem, RestrictSUIDSGID, CapabilityBoundingSet,
# SystemCallFilter. Re-verify on the target if you tighten further.
ProtectHome=true
PrivateTmp=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
LockPersonality=true
RestrictRealtime=true

[Install]
WantedBy=multi-user.target
EOF
}

write_permissions() {
  # Declare hostek's fine-grained rights to the holistic rights standard (drop-in) and
  # create their backing Linux groups. Each right is admin-only by default (default:false):
  # without privleg the groups stay empty, so behaviour is exactly as before. privleg lets
  # an admin grant a specific non-admin one of these rights = add them to the group.
  # The daemon (api.go) and the UI enforce `isAdmin || group ∈ user.groups`.
  install -d -o "$HOLISTIC_GROUP" -g "$HOLISTIC_GROUP" -m 0755 /etc/holistic/permissions.d 2>/dev/null \
    || install -d -m 0755 /etc/holistic/permissions.d
  cat > "$PERMS_FILE" <<'JSON'
{
  "service": "hostek",
  "version": 1,
  "categories": [
    {
      "id": "system",
      "label": "System",
      "description": "Energie- und Systemsteuerung.",
      "permissions": [
        {
          "id": "power",
          "label": "Power-Steuerung",
          "description": "OS-Energieeinstellungen und den Headless-/Always-on-Modus ändern.",
          "group": "hp_hostek_power",
          "default": false,
          "dangerous": true
        }
      ]
    },
    {
      "id": "insight",
      "label": "Einblick",
      "description": "Erweiterte Einblicke in Prozesse und Hardware.",
      "permissions": [
        {
          "id": "processes",
          "label": "Prozessliste",
          "description": "Laufende Prozesse und ihre CPU-/RAM-/Netz-Nutzung einsehen.",
          "group": "hp_hostek_proc",
          "default": false
        },
        {
          "id": "powerinfo",
          "label": "Energieinformationen",
          "description": "Stromverbrauch (Watt) der Komponenten und den Power-Tab einsehen.",
          "group": "hp_hostek_powerinfo",
          "default": false
        },
        {
          "id": "thermal",
          "label": "Thermalinformationen",
          "description": "Temperaturwerte (CPU, GPU, Datenträger) und den Thermal-Tab einsehen.",
          "group": "hp_hostek_thermal",
          "default": false
        },
        {
          "id": "techinfo",
          "label": "Software-Informationen",
          "description": "Betriebsstunden, Firmware und Treiber einsehen.",
          "group": "hp_hostek_techinfo",
          "default": false
        },
        {
          "id": "hwdetail",
          "label": "Identitätsinformationen",
          "description": "Sensible Identifikatoren einsehen: Seriennummern und MAC-Adressen.",
          "group": "hp_hostek_hwdetail",
          "default": false,
          "sensitive": true
        },
        {
          "id": "disks",
          "label": "Datenträger",
          "description": "Den Disks-Tab mit allen Datenträgern einsehen.",
          "group": "hp_hostek_disks",
          "default": false
        }
      ]
    },
    {
      "id": "storage",
      "label": "Speicherverwaltung",
      "description": "Datenträger im Disks-Tab aktiv verwalten.",
      "permissions": [
